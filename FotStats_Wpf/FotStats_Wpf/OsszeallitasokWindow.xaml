<Window x:Class="FotStats.OsszeallitasokWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Összeállítások" Height="560" Width="950"
        WindowStartupLocation="CenterScreen"
        Background="#0F172A">

    <Window.Resources>

        <!-- Button -->
        <Style x:Key="RoundBtn" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.92"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TextBox -->
        <Style x:Key="RoundTextBox" TargetType="TextBox">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Background" Value="#0B1220"/>
            <Setter Property="Foreground" Value="#E5E7EB"/>
            <Setter Property="BorderBrush" Value="#25314A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Bd"
                                CornerRadius="12"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#3B82F6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Player row chip -->
        <Style x:Key="PlayerChip" TargetType="Border">
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Background" Value="#111827"/>
            <Setter Property="BorderBrush" Value="#25314A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

    </Window.Resources>

    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                CornerRadius="16"
                Background="#111827"
                Padding="18"
                BorderBrush="#25314A"
                BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Összeállítások"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="White"/>
                    <TextBlock Text="Csapatok egyszer jelennek meg, alatta a játékosok (SQL-ből)"
                               Margin="0,6,0,0"
                               Foreground="#9CA3AF"/>
                </StackPanel>

                <Button Grid.Column="1"
                        Content="← Vissza"
                        Width="120"
                        Background="#1F2937"
                        Click="Vissza_Click"
                        Style="{StaticResource RoundBtn}"/>
            </Grid>
        </Border>

        <!-- Main -->
        <Border Grid.Row="1"
                Margin="0,18,0,18"
                CornerRadius="18"
                Background="#111827"
                BorderBrush="#25314A"
                BorderThickness="1"
                Padding="18">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Top controls -->
                <Grid Grid.Row="0" Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Grid>
                        <TextBox x:Name="SearchBox"
                                 Style="{StaticResource RoundTextBox}"
                                 TextChanged="SearchBox_TextChanged"/>

                        <TextBlock IsHitTestVisible="False"
                                   Margin="14,0,0,0"
                                   VerticalAlignment="Center"
                                   Foreground="#64748B"
                                   Text="Keresés: csapat / játékos / poszt / nemzetiség...">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>

                    <Button Grid.Column="1"
                            Content="Frissítés"
                            Width="130"
                            Margin="12,0,0,0"
                            Background="#2563EB"
                            Click="Frissites_Click"
                            Style="{StaticResource RoundBtn}"/>
                </Grid>

                <!-- Teams list -->
                <Grid Grid.Row="1">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="TeamsList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="14"
                                            Background="#0B1220"
                                            BorderBrush="#25314A"
                                            BorderThickness="1"
                                            Padding="14"
                                            Margin="0,0,0,10">
                                        <StackPanel>

                                            <TextBlock Text="{Binding CsapatNev}"
                                                       FontSize="16"
                                                       FontWeight="Bold"
                                                       Foreground="White"/>

                                            <ItemsControl ItemsSource="{Binding Jatekosok}" Margin="0,10,0,0">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Style="{StaticResource PlayerChip}">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="200"/>
                                                                    <ColumnDefinition Width="220"/>
                                                                </Grid.ColumnDefinitions>

                                                                <TextBlock Text="{Binding Nev}"
                                                                           Foreground="#E5E7EB"
                                                                           FontWeight="SemiBold"/>

                                                                <TextBlock Grid.Column="1"
                                                                           Text="{Binding Poszt}"
                                                                           Foreground="#CBD5E1"/>

                                                                <TextBlock Grid.Column="2"
                                                                           Text="{Binding Nemzetiseg}"
                                                                           Foreground="#94A3B8"/>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <TextBlock Text="Nincs játékos."
                                                       Foreground="#94A3B8"
                                                       Margin="0,8,0,0">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Jatekosok.Count}" Value="0">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>

                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <TextBlock x:Name="EmptyHint"
                               Text="Nincs adat."
                               Foreground="#94A3B8"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Visibility="Collapsed"/>
                </Grid>

            </Grid>
        </Border>

        <TextBlock Grid.Row="2"
                   Foreground="#94A3B8"
                   Text="DB: csapatok + jatekosok (csapat_id) — csoportosítva UI-ban"/>
    </Grid>
</Window>
