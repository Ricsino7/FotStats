<Window x:Class="FotStats.HirekWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Hírek" Height="650" Width="980"
        WindowStartupLocation="CenterScreen"
        Background="#0F172A">

    <Window.Resources>

        <!-- Modern kerek gomb -->
        <Style x:Key="RoundBtn" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.92"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Kerekített textbox -->
        <Style x:Key="RoundTextBox" TargetType="TextBox">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Background" Value="#0B1220"/>
            <Setter Property="Foreground" Value="#E5E7EB"/>
            <Setter Property="BorderBrush" Value="#25314A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border CornerRadius="12"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- News card -->
        <Style x:Key="NewsCardBorder" TargetType="Border">
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Background" Value="#111827"/>
            <Setter Property="BorderBrush" Value="#25314A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

    </Window.Resources>

    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" CornerRadius="16" Background="#111827" Padding="18"
                BorderThickness="1" BorderBrush="#25314A">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Hírek"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="White"/>
                    <TextBlock Text="Betöltés MySQL-ből (news tábla)"
                               Margin="0,6,0,0"
                               Foreground="#9CA3AF"
                               FontSize="13"/>
                </StackPanel>

                <Button Grid.Column="1"
                        Content="← Vissza"
                        Width="120"
                        Background="#1F2937"
                        Click="Vissza_Click"
                        Style="{StaticResource RoundBtn}"/>
            </Grid>
        </Border>

        <!-- Controls -->
        <Grid Grid.Row="1" Margin="0,14,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Grid>
                <TextBox x:Name="SearchBox"
                         Style="{StaticResource RoundTextBox}"
                         TextChanged="SearchBox_TextChanged"/>

                <!-- Placeholder -->
                <TextBlock IsHitTestVisible="False"
                           Margin="14,0,0,0"
                           VerticalAlignment="Center"
                           Foreground="#64748B"
                           Text="Keress: cím / forrás / összefoglaló...">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>

            <Button Grid.Column="1"
                    Content="Frissítés"
                    Width="130"
                    Margin="12,0,0,0"
                    Background="#2563EB"
                    Click="Frissites_Click"
                    Style="{StaticResource RoundBtn}"/>

            <Button Grid.Column="2"
                    Content="Új hír"
                    Width="130"
                    Margin="10,0,0,0"
                    Background="#10B981"
                    Click="UjHir_Click"
                    Style="{StaticResource RoundBtn}"/>
        </Grid>

        <!-- List -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="NewsList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource NewsCardBorder}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="170"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Image -->
                                <Border CornerRadius="12"
                                        Background="#0B1220"
                                        BorderBrush="#25314A"
                                        BorderThickness="1"
                                        Width="160"
                                        Height="110"
                                        VerticalAlignment="Top">
                                    <Image Source="{Binding KepFullPath}"
                                           Stretch="UniformToFill"
                                           ImageFailed="NewsImage_ImageFailed"/>
                                </Border>

                                <!-- Text -->
                                <StackPanel Grid.Column="1" Margin="14,0,0,0">
                                    <TextBlock Text="{Binding Cim}"
                                               Foreground="White"
                                               FontSize="16"
                                               FontWeight="Bold"
                                               TextWrapping="Wrap"/>

                                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                        <Border Background="#0B1220"
                                                BorderBrush="#25314A"
                                                BorderThickness="1"
                                                CornerRadius="10"
                                                Padding="10,6"
                                                Margin="0,0,8,0">
                                            <TextBlock Text="{Binding Datum}"
                                                       Foreground="#CBD5E1"/>
                                        </Border>

                                        <Border Background="#0B1220"
                                                BorderBrush="#25314A"
                                                BorderThickness="1"
                                                CornerRadius="10"
                                                Padding="10,6">
                                            <TextBlock Text="{Binding Forras}"
                                                       Foreground="#CBD5E1"/>
                                        </Border>
                                    </StackPanel>

                                    <TextBlock Text="{Binding Osszefoglalo}"
                                               Margin="0,10,0,0"
                                               Foreground="#E5E7EB"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Footer -->
        <TextBlock Grid.Row="3"
                   Margin="0,10,0,0"
                   Foreground="#94A3B8"
                   Text="Képek: tedd a fájlokat pl. ./img/news/ mappába (slot.jpg, sesko.jpg, stb.)."/>
    </Grid>
</Window>
