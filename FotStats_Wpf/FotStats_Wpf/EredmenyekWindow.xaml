<Window x:Class="FotStats.EredmenyekWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Eredmények / Tabella" Height="560" Width="980"
        WindowStartupLocation="CenterScreen"
        Background="#0F172A">

    <Window.Resources>

        <Style x:Key="RoundBtn" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.92"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkComboBoxItem" TargetType="ComboBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#E5E7EB"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1F2937"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2563EB"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkComboBox" TargetType="ComboBox">
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#E5E7EB"/>
            <Setter Property="Background" Value="#0B1220"/>
            <Setter Property="BorderBrush" Value="#25314A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource DarkComboBoxItem}"/>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#0B1220"/>
            <Setter Property="Foreground" Value="#E5E7EB"/>
            <Setter Property="BorderBrush" Value="#25314A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="RowBackground" Value="#0B1220"/>
            <Setter Property="AlternatingRowBackground" Value="#0F172A"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#111827"/>
            <Setter Property="Foreground" Value="#E5E7EB"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderBrush" Value="#25314A"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Foreground" Value="#E5E7EB"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#1F2937"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

    </Window.Resources>

    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                CornerRadius="16"
                Background="#111827"
                Padding="18"
                BorderBrush="#25314A"
                BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Eredmények / Tabella"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="White"/>
                    <TextBlock Text="Ligánként számolt tabella a meccsekből (C# számolja)"
                               Margin="0,6,0,0"
                               Foreground="#9CA3AF"/>
                </StackPanel>

                <Button Grid.Column="1"
                        Content="← Vissza"
                        Width="120"
                        Background="#1F2937"
                        Click="Vissza_Click"
                        Style="{StaticResource RoundBtn}"/>
            </Grid>
        </Border>

        <!-- Main card -->
        <Border Grid.Row="1"
                Margin="0,18,0,18"
                CornerRadius="18"
                Background="#111827"
                BorderBrush="#25314A"
                BorderThickness="1"
                Padding="18">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Controls -->
                <Grid Grid.Row="0" Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <ComboBox x:Name="LigaCombo"
                              Style="{StaticResource DarkComboBox}"
                              SelectionChanged="LigaCombo_SelectionChanged"/>

                    <Button Grid.Column="1"
                            Content="Frissítés"
                            Width="130"
                            Margin="12,0,0,0"
                            Background="#2563EB"
                            Click="Frissites_Click"
                            Style="{StaticResource RoundBtn}"/>
                </Grid>

                <!-- Table -->
                <Grid Grid.Row="1">
                    <DataGrid x:Name="TabellaGrid"
                              AutoGenerateColumns="False"
                              AlternationCount="2">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="#" Binding="{Binding Helyezes}" Width="50"/>
                            <DataGridTextColumn Header="Csapat" Binding="{Binding Csapat}" Width="*"/>
                            <DataGridTextColumn Header="M" Binding="{Binding Meccs}" Width="60"/>
                            <DataGridTextColumn Header="GY" Binding="{Binding Gyozelem}" Width="60"/>
                            <DataGridTextColumn Header="D" Binding="{Binding Dontetlen}" Width="60"/>
                            <DataGridTextColumn Header="V" Binding="{Binding Vereseg}" Width="60"/>
                            <DataGridTextColumn Header="LG" Binding="{Binding LottGol}" Width="70"/>
                            <DataGridTextColumn Header="KG" Binding="{Binding KapottGol}" Width="70"/>
                            <DataGridTextColumn Header="GK" Binding="{Binding Golkulonbseg}" Width="70"/>
                            <DataGridTextColumn Header="Pont" Binding="{Binding Pont}" Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <TextBlock x:Name="EmptyHint"
                               Text="Nincs meccs / nincs számolható eredmény ebben a ligában."
                               Foreground="#94A3B8"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Visibility="Collapsed"/>
                </Grid>

            </Grid>
        </Border>

        <TextBlock Grid.Row="2"
                   Foreground="#94A3B8"
                   Text="Megjegyzés: az eredmény formátum legyen 2-1 (szóköz lehet: 2 - 1)."/>
    </Grid>
</Window>
