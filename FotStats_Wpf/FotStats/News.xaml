<Window x:Class="FotStats.News"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FotStats"
        mc:Ignorable="d"
        Title="News" Height="450" Width="800">
    <Grid>
        <Menu Margin="0,0,0,404">
            <MenuItem Header="Matches"></MenuItem>
            <MenuItem Header="Results"></MenuItem>
            <MenuItem Header="Tournaments"></MenuItem>
            <MenuItem Header="Statisztikak"></MenuItem>
        </Menu>
        <Button Content="Kilépés" HorizontalAlignment="Left" Margin="38,341,0,0" VerticalAlignment="Top" Height="62" Width="129"/>
        <DataGrid HorizontalAlignment="Left" Height="217" Margin="38,67,0,0" VerticalAlignment="Top" Width="598" d:ItemsSource="{d:SampleData ItemCount=5}"/>
    </Grid>
</Window>
