<Window x:Class="FotStats.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FotStats" Height="520" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#0F172A">

    <!-- ✅ Resources felül, hogy a StaticResource működjön -->
    <Window.Resources>
        <Style x:Key="NavBtn" TargetType="Button">
            <Setter Property="Height" Value="92"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#1F2937"/>
            <Setter Property="BorderBrush" Value="#2D3B57"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="16"
                                Padding="18">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Text="{TemplateBinding Content}"
                                           FontSize="{TemplateBinding FontSize}"
                                           FontWeight="{TemplateBinding FontWeight}"
                                           Foreground="{TemplateBinding Foreground}"/>

                                <TextBlock Grid.Row="1"
                                           Margin="0,8,0,0"
                                           Text="Megnyitás →"
                                           Foreground="#9CA3AF"
                                           FontSize="13"/>
                            </Grid>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#243244"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#3B82F6"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1A2433"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" CornerRadius="16" Background="#111827" Padding="18" BorderThickness="1" BorderBrush="#25314A">
            <StackPanel>
                <TextBlock Text="FotStats" FontSize="30" FontWeight="Bold" Foreground="White"/>
                <TextBlock Text="Meccsek • Eredmények • Összeállítások • Hírek"
                           Margin="0,6,0,0" Foreground="#9CA3AF" FontSize="13"/>
            </StackPanel>
        </Border>

        <!-- Main -->
        <Border Grid.Row="1" Margin="0,18,0,18"
                CornerRadius="18" Background="#111827"
                BorderThickness="1" BorderBrush="#25314A"
                Padding="22">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Válassz egy modult"
                           FontSize="18" FontWeight="SemiBold"
                           Foreground="White" Margin="0,0,0,16"/>

                <UniformGrid Grid.Row="1" Columns="2" Rows="2">
                    <Button Content="Meccsek" Click="Meccsek_Click" Style="{StaticResource NavBtn}" Margin="10"/>
                    <Button Content="Eredmények" Click="Eredmenyek_Click" Style="{StaticResource NavBtn}" Margin="10"/>
                    <Button Content="Összeállítások" Click="Osszeallitasok_Click" Style="{StaticResource NavBtn}" Margin="10"/>
                    <Button Content="Hírek" Click="Hirek_Click" Style="{StaticResource NavBtn}" Margin="10"/>
                </UniformGrid>
            </Grid>
        </Border>

        <!-- Footer -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock VerticalAlignment="Center" Foreground="#94A3B8"
                       Text="FotStats • WPF alap"/>

            <Button Grid.Column="1"
                    Content="Kilépés"
                    Click="Kilepes_Click"
                    Width="140" Height="42"
                    Margin="12,0,0,0"
                    Background="#EF4444"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"
                    FontWeight="SemiBold">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="12" Padding="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>
    </Grid>
</Window>
