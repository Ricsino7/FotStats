<Window x:Class="FotStats.MeccsekWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Meccsek" Height="520" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#0F172A">

    <Window.Resources>

        <!-- Modern kerek gomb -->
        <Style x:Key="RoundBtn" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Input box kerekítve -->
        <Style x:Key="RoundTextBox" TargetType="TextBox">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Background" Value="#0B1220"/>
            <Setter Property="Foreground" Value="#E5E7EB"/>
            <Setter Property="BorderBrush" Value="#25314A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border CornerRadius="12"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Match card kinézet -->
        <Style x:Key="MatchCardBorder" TargetType="Border">
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Background" Value="#0B1220"/>
            <Setter Property="BorderBrush" Value="#25314A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

    </Window.Resources>

    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" CornerRadius="16" Background="#111827" Padding="18"
                BorderThickness="1" BorderBrush="#25314A">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Meccsek"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="White"/>
                    <TextBlock Text="Keresés + lista (később SQL-ből töltjük)"
                               Margin="0,6,0,0"
                               Foreground="#9CA3AF"
                               FontSize="13"/>
                </StackPanel>

                <Button Grid.Column="1"
                        Content="← Vissza"
                        Click="Vissza_Click"
                        Width="120"
                        Background="#1F2937"
                        BorderBrush="#2D3B57"
                        BorderThickness="1"
                        Foreground="White"
                        Cursor="Hand"
                        FontWeight="SemiBold">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="12"
                                    Padding="10">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

            </Grid>
        </Border>

        <!-- Main card -->
        <Border Grid.Row="1" Margin="0,18,0,18"
                CornerRadius="18"
                Background="#111827"
                BorderThickness="1"
                BorderBrush="#25314A"
                Padding="18">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Filter row -->
                <Grid Grid.Row="0" Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Grid>
                        <TextBox x:Name="SearchBox"
                                 Style="{StaticResource RoundTextBox}"
                                 TextChanged="SearchBox_TextChanged"/>

                        <!-- Placeholder -->
                        <TextBlock IsHitTestVisible="False"
                                   Margin="14,0,0,0"
                                   VerticalAlignment="Center"
                                   Foreground="#64748B"
                                   Text="Keress: liga / csapat / dátum / eredmény...">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>

                    <Button Grid.Column="1"
                            Content="Frissítés"
                            Width="130"
                            Margin="12,0,0,0"
                            Click="Frissites_Click"
                            Background="#2563EB"
                            Style="{StaticResource RoundBtn}"/>

                    <Button Grid.Column="2"
                            Content="Új meccs"
                            Width="130"
                            Margin="10,0,0,0"
                            Click="UjMeccs_Click"
                            Background="#10B981"
                            Style="{StaticResource RoundBtn}"/>
                </Grid>

                <!-- Cards list -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="MatchesCards">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource MatchCardBorder}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel>
                                            <TextBlock Text="{Binding Hazai}"
                                                       FontSize="16"
                                                       FontWeight="Bold"
                                                       Foreground="White"/>
                                            <TextBlock Text="{Binding Vendeg}"
                                                       Margin="0,3,0,0"
                                                       FontSize="16"
                                                       FontWeight="Bold"
                                                       Foreground="White"/>

                                            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                                <Border Background="#111827" CornerRadius="10" Padding="10,6" Margin="0,0,8,0"
                                                        BorderBrush="#25314A" BorderThickness="1">
                                                    <TextBlock Text="{Binding Liga}" Foreground="#CBD5E1"/>
                                                </Border>

                                                <Border Background="#111827" CornerRadius="10" Padding="10,6"
                                                        BorderBrush="#25314A" BorderThickness="1">
                                                    <TextBlock Text="{Binding Datum}" Foreground="#CBD5E1"/>
                                                </Border>
                                            </StackPanel>
                                        </StackPanel>

                                        <Border Grid.Column="1"
                                                Background="#0F172A"
                                                BorderBrush="#25314A"
                                                BorderThickness="1"
                                                CornerRadius="12"
                                                Padding="14,10"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Eredmeny}"
                                                       FontSize="18"
                                                       FontWeight="Bold"
                                                       Foreground="White"/>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

            </Grid>
        </Border>

        <!-- Footer -->
        <TextBlock Grid.Row="2"
                   Foreground="#94A3B8"
                   Text="Tipp: ide kötjük majd az SQL lekérést (meccsek + csapatok JOIN)."/>
    </Grid>
</Window>
