<Window x:Class="FotStats.Statisztikak"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FotStats"
        mc:Ignorable="d"
        Title="Statisztikak" Height="450" Width="800">
    <Grid>
        <Menu Margin="0,0,0,404">
            <MenuItem Header="Matches"></MenuItem>
            <MenuItem Header="Results"></MenuItem>
            <MenuItem Header="Tournaments"></MenuItem>
            <MenuItem Header="News"></MenuItem>
        </Menu>
        <DataGrid HorizontalAlignment="Left" Height="249" Margin="20,47,0,0" VerticalAlignment="Top" Width="564" d:ItemsSource="{d:SampleData ItemCount=5}"/>
        <Button Content="Kilépés" HorizontalAlignment="Left" Margin="20,346,0,0" VerticalAlignment="Top" Height="60" Width="115"/>
    </Grid>
</Window>
